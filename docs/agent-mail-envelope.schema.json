{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-mail.local/schemas/agent-mail-envelope-1.0.schema.json",
  "title": "Agent Mail Envelope",
  "description": "Core v1 Agent Mail message envelope for routing, correlation, acknowledgement, privacy, and audit.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocol",
    "version",
    "id",
    "conversation_id",
    "from",
    "to",
    "subject",
    "created_at",
    "body_type",
    "body",
    "ack_requested",
    "delivery_state",
    "privacy"
  ],
  "properties": {
    "protocol": {
      "const": "agent-mail"
    },
    "version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "id": {
      "type": "string",
      "pattern": "^msg_[A-Za-z0-9_-]+$",
      "description": "Globally unique message ID. Retries preserve this value."
    },
    "conversation_id": {
      "type": "string",
      "pattern": "^conv_[A-Za-z0-9_-]+$",
      "description": "Durable logical conversation ID, independent of transport-specific thread or session IDs."
    },
    "from": {
      "$ref": "#/$defs/mailbox"
    },
    "to": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mailbox"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reply_to": {
      "type": ["string", "null"],
      "pattern": "^msg_[A-Za-z0-9_-]+$",
      "default": null
    },
    "body_type": {
      "type": "string",
      "enum": ["text/plain", "text/markdown", "application/json"]
    },
    "body": {
      "description": "Message payload. Type is constrained by body_type: string for text/plain and text/markdown, object or array for application/json.",
      "oneOf": [
        {"type": "string"},
        {"type": "object", "additionalProperties": true},
        {"type": "array", "items": true}
      ]
    },
    "ack_requested": {
      "type": "boolean",
      "description": "Whether the sender asks the receiver to acknowledge responsibility for handling the message."
    },
    "delivery_state": {
      "$ref": "#/$defs/delivery_state"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"],
      "default": "normal"
    },
    "ttl_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Stable sender-defined key for duplicate-safe operations."
    },
    "requires_human_visible_ledger": {
      "type": "boolean",
      "default": true
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attachment"
      },
      "default": []
    },
    "capability_hints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string"
        },
        "parent_message_id": {
          "type": "string",
          "pattern": "^msg_[A-Za-z0-9_-]+$"
        }
      }
    },
    "transport_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transport_ref"
      },
      "description": "Safe-to-expose transport metadata such as Discord channel/thread/message IDs or MCP server names."
    },
    "state_reason": {
      "type": "string",
      "description": "Machine- or human-readable reason when delivery_state is rejected, failed, or expired."
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Namespaced extension payloads, for example openclaw.approval or discord.ledger_ref."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"body_type": {"enum": ["text/plain", "text/markdown"]}},
        "required": ["body_type"]
      },
      "then": {
        "properties": {"body": {"type": "string"}}
      }
    },
    {
      "if": {
        "properties": {"body_type": {"const": "application/json"}},
        "required": ["body_type"]
      },
      "then": {
        "properties": {"body": {"oneOf": [{"type": "object"}, {"type": "array"}]}}
      }
    }
  ],
  "$defs": {
    "mailbox": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$",
      "description": "Stable logical mailbox alias."
    },
    "delivery_state": {
      "type": "string",
      "enum": [
        "created",
        "queued",
        "sent",
        "delivered",
        "acknowledged",
        "rejected",
        "failed",
        "expired"
      ]
    },
    "privacy": {
      "type": "string",
      "enum": ["public", "shared", "private", "secret"]
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "mime_type", "name", "privacy"],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "privacy": {
          "$ref": "#/$defs/privacy"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "transport_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": ["transport"],
      "properties": {
        "transport": {
          "type": "string",
          "enum": ["discord", "mcp", "acp", "http", "file", "email", "runtime"]
        },
        "channel_id": {
          "type": "string"
        },
        "thread_id": {
          "type": "string"
        },
        "message_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "server": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  },
  "examples": [
    {
      "protocol": "agent-mail",
      "version": "1.0",
      "id": "msg_01jzabc123",
      "conversation_id": "conv_01jzabc123",
      "from": "clara",
      "to": ["kjb-agent"],
      "subject": "M1 vertical slice",
      "created_at": "2026-06-13T22:58:45Z",
      "reply_to": null,
      "body_type": "text/markdown",
      "body": "Can you ACK this Agent Mail envelope?",
      "ack_requested": true,
      "delivery_state": "created",
      "priority": "normal",
      "privacy": "shared",
      "requires_human_visible_ledger": true,
      "attachments": []
    }
  ]
}
